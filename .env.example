# ─── Requeridas ───────────────────────────────────────────────────────────────

# Clave secreta para firmar y verificar los tokens JWT.
# Usa al menos 32 caracteres aleatorios. Puedes generar una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secret-key-minimum-32-chars

# URL de conexión a la base de datos (SQLAlchemy async).
# Para desarrollo local con SQLite:
#   sqlite+aiosqlite:///./dev.db
# Para producción con MySQL:
#   mysql+aiomysql://usuario:contraseña@host:3306/nombre_db
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# URL base del servicio Engine (el motor de simulaciones de tráfico).
# El backend le hará peticiones a {ENGINE_API_URL}/simulations/{id} y {ENGINE_API_URL}/health
ENGINE_API_URL=http://engine-service:8000

# ─── Opcionales ───────────────────────────────────────────────────────────────

# Clave separada para cifrar los datos de simulaciones en la base de datos (cifrado Fernet).
# Si se deja vacía, se usará SECRET_KEY como fallback.
# Recomendado: usar una clave distinta a SECRET_KEY en producción.
DATA_ENCRYPTION_KEY=

# Algoritmo usado para firmar los tokens JWT. No cambiar salvo que sea necesario.
ALGORITHM=HS256

# Tiempo de vida de los tokens JWT en minutos.
# Al expirar, el usuario deberá iniciar sesión de nuevo.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Si se establece en true, el backend creará las tablas en la DB automáticamente al arrancar.
# Útil en desarrollo. En producción es preferible usar migraciones (ej. Alembic).
CREATE_TABLES_ON_STARTUP=false

# Nivel de detalle de los logs. Opciones: DEBUG | INFO | WARNING | ERROR
# DEBUG muestra mucho más detalle, útil al desarrollar.
LOG_LEVEL=INFO

# Ruta del archivo de log rotativo. Se rotará automáticamente cada 10 MB (máximo 5 archivos).
# Si se deja vacío, los logs solo se imprimirán en consola.
LOG_FILE=logs/app.txt

# Nombre y versión de la aplicación. Se muestran en la documentación automática de Swagger UI.
APP_NAME=Backend API
APP_VERSION=0.1.0

# Lista de orígenes permitidos por CORS (en formato JSON).
# Agrega aquí las URLs desde donde el frontend hará peticiones al backend.
# Ejemplo con varios orígenes: ["http://localhost:3000", "https://tu-dominio.com"]
CORS_ORIGINS=["http://localhost:3000"]