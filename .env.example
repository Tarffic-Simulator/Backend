# ─── Requeridas ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-minimum-32-chars
# Async drivers: sqlite+aiosqlite:/// o mysql+aiomysql://user:pass@host:3306/db
DATABASE_URL=sqlite+aiosqlite:///./dev.db
ENGINE_API_URL=http://engine-service:8000

# ─── Opcionales ───────────────────────────────────────────────────────────────
DATA_ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CREATE_TABLES_ON_STARTUP=false
LOG_LEVEL=INFO
LOG_FILE=logs/app.txt
APP_NAME=Backend API
APP_VERSION=0.1.0

# Orígenes permitidos por CORS (JSON list)
CORS_ORIGINS=["http://localhost:3000"]